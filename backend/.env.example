# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=SpiceSibyl API
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Security ──────────────────────────────────────────────────────────────────
API_KEY=change-me
# Master secret for Fernet encryption of vaulted API keys — CHANGE THIS
VAULT_SECRET_KEY=change-me-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:80

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=/data/spice_sibyl.db

# ── Models ────────────────────────────────────────────────────────────────────
DEFAULT_MODEL=ollama/qwen2.5:7b-instruct
LITELLM_PROVIDER=litellm
OLLAMA_API_BASE=http://host.docker.internal:11434
MODEL_CATALOG_PATH=/config/provider_models.yaml

# Multi-MCP orchestrator sidecar (agent/* models). Empty = disabled.
# The sidecar (agent_server.py) runs on the host next to the multi-mcp CLI.
ORCHESTRATOR_BASE_URL=http://host.docker.internal:8910/v1

# ── Provider API keys (set the ones you use) ─────────────────────────────────
OPENAI_API_KEY=dummy
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
MISTRAL_API_KEY=
CEREBRAS_API_KEY=
NVIDIA_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
HF_TOKEN=

# ── Telegram bot (leave empty to disable) ────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_DEFAULT_MODEL=

# ── Image generation (text-to-image) ─────────────────────────────────────────
# Comma-separated "provider:model" pairs tried in order with automatic fallback.
# Supported providers: gemini, huggingface, cloudflare, together_ai
IMAGE_GENERATION_CHAIN=gemini:gemini-2.5-flash-image,gemini:gemini-3.1-flash-image,gemini:gemini-3-pro-image,gemini:imagen-4.0-fast-generate-001,huggingface:black-forest-labs/FLUX.1-schnell,cloudflare:@cf/stabilityai/stable-diffusion-xl-base-1.0,together_ai:black-forest-labs/FLUX.1-schnell-Free
